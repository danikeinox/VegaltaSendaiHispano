generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Socio de la comunidad hispana Vegalta Sendai
model Member {
  id           String   @id @default(cuid())
  memberNumber Int      @unique
  displayId    String   @unique @map("display_id")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  email        String   @unique
  country      String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([email])
  @@map("members")
}

/// Contador atómico para IDs consecutivos (VS-0001, VS-0002...)
model IdSequence {
  id    Int @id @default(1)
  value Int @default(0)

  @@map("id_sequence")
}
