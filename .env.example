# Appwrite — Cliente (público)
NEXT_PUBLIC_APPWRITE_PROJECT_ID="6a2702ec000b42a91782"
NEXT_PUBLIC_APPWRITE_PROJECT_NAME="VegaltaSendaiHispano"
NEXT_PUBLIC_APPWRITE_ENDPOINT="https://fra.cloud.appwrite.io/v1"

# Appwrite — Servidor (API key, NUNCA exponer al cliente)
# Tras actualizar el esquema de seguridad, ejecutar: npm run appwrite:setup
APPWRITE_API_KEY=""
APPWRITE_DATABASE_ID="vegalta_sendai"
APPWRITE_MEMBERS_COLLECTION_ID="members"
APPWRITE_SEQUENCE_COLLECTION_ID="id_sequence"
APPWRITE_SEQUENCE_DOCUMENT_ID="member_counter"

# Dominio de la aplicación (CORS, CSRF, CSP, enlaces públicos)
# Usa solo el origen: https://www.vegalta.es (sin /* ni barra final; se normalizan si se añaden por error)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Secreto HMAC para tokens de verificación de carnet (generar con: openssl rand -base64 32)
MEMBER_VERIFICATION_SECRET=""

# Apoyo al proyecto (Buy Me a Coffee) — opcional
# NEXT_PUBLIC_BUYMEACOFFEE_URL="https://buymeacoffee.com/tuusuario"
ALLOWED_ORIGIN="http://localhost:3000"

# Registro de socios — "false" para habilitar (temporalmente deshabilitado por seguridad)
REGISTRATION_DISABLED="false"

# Rate limiting — Upstash Redis (obligatorio en producción)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Recuperación de carnet por email (Resend — opcional pero recomendado en producción)
RESEND_API_KEY=""
RECOVERY_EMAIL_FROM="Vegalta Hispano <noreply@vegalta.es>"

# Cloudflare Turnstile (recomendado en producción para el registro)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# API-Football (api-sports.io) — resultados Vegalta Sendai (caché 24h, ~2 req/día)
API_FOOTBALL_KEY=""
API_FOOTBALL_TEAM_ID="289"
API_FOOTBALL_SEASON="2026"
# Opcional: filtrar solo J1 (98). Sin valor = todos los partidos del equipo en la temporada
# API_FOOTBALL_LEAGUE_ID="98"

# Apple Wallet / PassKit
APPLE_PASS_TYPE_IDENTIFIER="pass.com.vegalta.hispano"
APPLE_TEAM_IDENTIFIER="XXXXXXXXXX"
APPLE_PASS_CERT_PATH="./certs/signerCert.pem"
APPLE_PASS_KEY_PATH="./certs/signerKey.pem"
APPLE_WWDR_CERT_PATH="./certs/wwdr.pem"
# Cloudflare Workers — PEM completo en secrets
# APPLE_PASS_CERT="-----BEGIN CERTIFICATE-----\n..."
# APPLE_PASS_KEY="-----BEGIN PRIVATE KEY-----\n..."
# APPLE_WWDR_CERT="-----BEGIN CERTIFICATE-----\n..."
APPLE_PASS_KEY_PASSPHRASE=""

# Google Wallet API
GOOGLE_WALLET_ISSUER_ID=""
GOOGLE_WALLET_CLASS_ID="vegalta_hispano_member"
GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_WALLET_SERVICE_ACCOUNT_PRIVATE_KEY=""

# Entorno
NODE_ENV="development"

# --- Despliegue en Cloudflare (GitHub Actions) ---
# Las variables no secretas van en wrangler.jsonc → "vars".
# Los secretos van en GitHub → Settings → Secrets and variables → Actions.
# Lista completa: .github/deploy-secrets.env.example
# El workflow deploy-cloudflare.yml los sube con `wrangler secret bulk` en cada deploy.
